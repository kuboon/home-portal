# IdP origin for passkey sign-in (delegated). Default: https://id.kbn.one
IDP_ORIGIN=https://id.kbn.one

# Turso (libSQL) endpoint.
# Local dev: run `turso dev` and use the URL it prints.
TURSO_DATABASE_URL=http://127.0.0.1:8080

# Auth token for a hosted Turso database. Leave empty for local `turso dev`.
TURSO_AUTH_TOKEN=
